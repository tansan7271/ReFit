{
  "expo": {
    "name": "ReFit",
    "slug": "refit",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "scheme": "refit",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tansan7271.refit",
      "infoPlist": {
        "NSHealthShareUsageDescription": "운동 전 컨디션 분석과 운동 후 회복 가이드를 위해 수면·심박·활동량·체중 데이터를 읽어옵니다.",
        "NSHealthUpdateUsageDescription": "운동 기록을 건강 앱에 저장하기 위해 사용됩니다.",
        "NSLocationWhenInUseUsageDescription": "오늘의 날씨를 기반으로 컨디션 리포트를 제공하기 위해 현재 위치를 사용합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.refit.app",
      "permissions": [
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_WEIGHT",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-background-fetch",
      "expo-task-manager",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#1A5CCC"
        }
      ],
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false,
          "healthSharePermission": "운동 전후 케어를 위해 건강 데이터를 읽어옵니다.",
          "healthUpdatePermission": "운동 기록을 건강 앱에 저장합니다."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "오늘의 날씨를 기반으로 컨디션 리포트를 제공하기 위해 현재 위치를 사용합니다."
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "dbcf71f9-410f-4ee2-ae82-15bc86f1bb05"
      }
    },
    "owner": "tansan7271"
  }
}
