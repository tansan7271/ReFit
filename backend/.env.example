# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=ReFit API
DEBUG=false

# CORS — 웹 브라우저 개발/배포용 origin (RN 앱은 CORS 미적용). JSON 배열 형식.
# 개발: ["http://localhost:8081","http://localhost:3000"]
# 프로덕션: 앱 웹 도메인만 지정 (예: ["https://app.refit.example.com"])
CORS_ORIGINS=["http://localhost:8081","http://localhost:3000"]

# ── Database (MySQL) ───────────────────────────────────────────────────────────
DB_HOST=db           # Docker Compose 서비스명 (로컬 직접 실행 시 localhost)
DB_PORT=3306
DB_USER=refit_user
DB_PASSWORD=your_strong_password_here
DB_NAME=refit

MYSQL_ROOT_PASSWORD=your_strong_root_password_here

# ── JWT ────────────────────────────────────────────────────────────────────────
# 생성: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Google Gemini ───────────────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── OpenWeather ─────────────────────────────────────────────────────────────────
# https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-api-key

# ── Cloudflare Tunnel ───────────────────────────────────────────────────────────
# Cloudflare Zero Trust → Networks → Tunnels → 터널 생성 후 토큰 복사
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token
